// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  phone       String?   @unique
  password    String
  isVerified  Boolean   @default(false)
  fcmToken    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  resetToken        String?
  resetTokenExpiry  DateTime?

  // Relations
  settings          UserSettings?
  banks             BankAccount[]
  expenses          Expense[]
  creditCards       CreditCard[]
  monthData         MonthData[]
  monthlyBalances   MonthlyBalance[]
}

model UserSettings {
  id              String  @id @default(uuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id])
  monthlySalary   Float   @default(56000)
  savingsPct      Float   @default(0.30)
  efTargetMonths  Float   @default(6)
  flatDpTarget    Float   @default(200000)
  defaultRd       Float   @default(13000)
  defaultSip      Float   @default(500)
  defaultChit     Float   @default(2000)
  defaultEf       Float   @default(5000)
}

model BankAccount {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  bankName        String
  accountNumber   String
  holderName      String
  accountType     String
  ifscCode        String?
  branchAddress   String?
  nickname        String?
  balance         Float            @default(0)
  createdAt       DateTime         @default(now())
  expenses        Expense[]
  monthlyBalances MonthlyBalance[]
}

model CreditCard {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  bankName        String
  nickname        String
  outstandingBill Float     @default(0)
  cycleSpend      Float     @default(0)
  billingDate     Int       @default(20)
  dueDate         Int       @default(5)
  creditLimit     Float     @default(100000)
  createdAt       DateTime  @default(now())
  expenses        Expense[]
}

model MonthlyBalance {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  bankId       String
  bank         BankAccount @relation(fields: [bankId], references: [id])
  month        String
  balanceType  String      // "opening" or "closing"
  amount       Float
  note         String?
  createdAt    DateTime    @default(now())

  @@unique([userId, bankId, month, balanceType])
}

model MonthData {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  month            String    // Format "Mar '26"
  openingBalance   Float     @default(0)
  salary           Float     @default(0)
  freelance        Float     @default(0)
  otherIncome      Float     @default(0)
  rdAmount         Float     @default(0)
  sipAmount        Float     @default(0)
  chitAmount       Float     @default(0)
  efContribution   Float     @default(0)
  savingsDeducted  Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([userId, month])
}

model Expense {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  amount        Float
  categoryId    String
  note          String?
  date          DateTime
  month         String
  paymentMethod String
  bankId        String?
  bank          BankAccount? @relation(fields: [bankId], references: [id])
  cardId        String?
  card          CreditCard?  @relation(fields: [cardId], references: [id])
  createdAt     DateTime     @default(now())
}
